# config.yaml — generated by Ansible (do not edit on server, changes will be overwritten)
# To change settings: edit ansible/roles/crypto-trader/vars/main.yml and re-run playbook

# ── Exchange ──────────────────────────────────────────────────────────────────
exchange:
  name: krakenfutures
  api_key:    "{{ kraken_api_key }}"
  api_secret: "{{ kraken_api_secret }}"
  testnet: false

# ── Symbols to Watch ──────────────────────────────────────────────────────────
symbols:
{% for symbol in trader_symbols %}
  - "{{ symbol }}"
{% endfor %}

# ── Strategy Parameters ───────────────────────────────────────────────────────
min_confluence_score:      {{ min_confluence_score }}
scan_interval_minutes:     {{ scan_interval_minutes }}
min_consolidation_candles: 8

# ── Risk Management ───────────────────────────────────────────────────────────
risk_per_trade_pct:    {{ risk_per_trade_pct }}
max_open_positions:    {{ max_open_positions }}
stop_loss_buffer_pct:  {{ stop_loss_buffer_pct }}
trailing_stop_pct:     {{ trailing_stop_pct }}

# ── Telegram Alerts ───────────────────────────────────────────────────────────
alerts:
  telegram:
    enabled:    true
    bot_token:  "{{ telegram_bot_token }}"
    chat_id:    "{{ telegram_chat_id }}"

# ── Webhook Server ────────────────────────────────────────────────────────────
webhook:
  secret: "{{ webhook_secret }}"
  restrict_to_tradingview_ips: false

# ── Dry Run Mode ──────────────────────────────────────────────────────────────
dry_run: {{ dry_run | lower }}

# ── Logging ───────────────────────────────────────────────────────────────────
log_level: INFO
