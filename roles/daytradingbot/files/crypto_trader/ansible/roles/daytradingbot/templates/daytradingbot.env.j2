# ============================================================
# .env — Kraken Day Trading Bot
# Deployed by Ansible — DO NOT EDIT MANUALLY ON SERVER
# Changes here will be overwritten on next playbook run.
# Edit vars in: host_vars/bandit.yml + group_vars/vault.yml
# Last deployed: {{ ansible_date_time.iso8601 }}
# ============================================================

# ── Kraken Futures API Credentials ───────────────────────────
KRAKEN_API_KEY={{ vault_daytradingbot_kraken_api_key }}
KRAKEN_API_SECRET={{ vault_daytradingbot_kraken_api_secret }}
KRAKEN_TESTNET={{ daytradingbot_kraken_testnet }}

# ── Telegram Notifications ────────────────────────────────────
TELEGRAM_BOT_TOKEN={{ vault_daytradingbot_telegram_bot_token }}
TELEGRAM_CHAT_ID={{ vault_daytradingbot_telegram_chat_id }}

# ── Trading Parameters ────────────────────────────────────────
MIN_CONFLUENCE_SCORE={{ daytradingbot_min_confluence_score }}
RISK_PER_TRADE_PCT={{ daytradingbot_risk_per_trade_pct }}
MAX_OPEN_POSITIONS={{ daytradingbot_max_open_positions }}
STOP_LOSS_BUFFER_PCT={{ daytradingbot_stop_loss_buffer_pct }}
TRAILING_STOP_PCT={{ daytradingbot_trailing_stop_pct }}
SCAN_INTERVAL_MINUTES={{ daytradingbot_scan_interval_minutes }}
MIN_CONSOLIDATION_CANDLES={{ daytradingbot_min_consolidation_candles }}

# ── Symbols ───────────────────────────────────────────────────
SYMBOLS={{ daytradingbot_symbols }}

# ── Webhook Server ────────────────────────────────────────────
# NOTE: Always 127.0.0.1 — cloudflared connects internally
SERVER_HOST=127.0.0.1
SERVER_PORT={{ daytradingbot_port }}
WEBHOOK_SECRET={{ vault_daytradingbot_webhook_secret }}

# ── Risk Controls ─────────────────────────────────────────────
DRY_RUN={{ daytradingbot_dry_run }}

# ── Logging ───────────────────────────────────────────────────
TRADE_LOG_FILE={{ daytradingbot_trade_log }}
