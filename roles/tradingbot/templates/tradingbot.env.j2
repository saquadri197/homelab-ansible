# ============================================================
# .env — Black Cat Trading Bot
# Deployed by Ansible — DO NOT EDIT MANUALLY ON SERVER
# Changes here will be overwritten on next playbook run.
# Edit vars in: host_vars/enigma.yml + group_vars/vault.yml
# Last deployed: {{ ansible_date_time.iso8601 }}
# ============================================================

# ── Blofin API Credentials ───────────────────────────────────
BLOFIN_API_KEY={{ vault_tradingbot_blofin_api_key }}
BLOFIN_API_SECRET={{ vault_tradingbot_blofin_api_secret }}
BLOFIN_PASSPHRASE={{ vault_tradingbot_blofin_passphrase }}
BLOFIN_BASE_URL=https://openapi.blofin.com
BLOFIN_DEMO_MODE={{ tradingbot_demo_mode }}

# ── Telegram Notifications ────────────────────────────────────
TELEGRAM_BOT_TOKEN={{ vault_tradingbot_telegram_bot_token }}
TELEGRAM_CHAT_ID={{ vault_tradingbot_telegram_chat_id }}

# ── Trading Parameters ────────────────────────────────────────
LEVERAGE={{ tradingbot_leverage }}
RISK_PERCENT={{ tradingbot_risk_percent }}
MAX_POSITIONS={{ tradingbot_max_positions }}
ATR_MULT_SL={{ tradingbot_atr_mult_sl }}
RR_RATIO={{ tradingbot_rr_ratio }}
DEFAULT_INST_ID={{ tradingbot_default_inst_id }}

# ── Webhook Server ────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT={{ tradingbot_port }}
WEBHOOK_SECRET={{ vault_tradingbot_webhook_secret }}

# ── Logging ───────────────────────────────────────────────────
TRADE_LOG_FILE={{ tradingbot_trade_log }}
